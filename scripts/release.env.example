# Copy to scripts/release.env and fill in values. release.env is gitignored.
#
# Check what's missing:
#   ./scripts/check-release-credentials.sh

# --- Git (optional overrides) ---
# RELEASE_GIT_REMOTE=origin
# RELEASE_GIT_BRANCH=main

# --- Chrome Web Store ---
# Extension ID from Chrome Developer Dashboard → Nunus → Package
CHROME_EXTENSION_ID=
# Optional: Publisher ID for automatic pending-review checks (Account / API access page)
# CHROME_PUBLISHER_ID=
# OAuth client from Google Cloud Console (Chrome Web Store API enabled)
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
# One-time OAuth flow; see scripts/docs/chrome-oauth-setup.md or README release section
CHROME_REFRESH_TOKEN=

# --- Firefox Add-ons (AMO) ---
# Developer Hub → Tools → Manage API Keys
AMO_JWT_ISSUER=
AMO_JWT_SECRET=
# listed | unlisted
AMO_CHANNEL=listed
# Listing copy synced after web-ext sign (summary from manifest.json, body from docs/description.md)
# AMO_LOCALE=en-US
# AMO_DESCRIPTION_FILE=/path/to/description.md
# STORE_DESCRIPTION_FILE=/path/to/description.md

# --- Chrome Web Store (manual listing reminder after publish) ---
# CHROME_LISTING_REMINDER_SKIP=1

# --- Apple Mac App Store (Safari host app) ---
# Team ID from developer.apple.com/account → Membership
APPLE_TEAM_ID=
# Optional override (default: com.acypher.Nunus)
# MACOS_BUNDLE_ID=com.acypher.Nunus
# --- Apple iOS App Store (Safari, iPhone/iPad) ---
# The iOS Safari extension ships as a SEPARATE App Store app and is included in
# publish-stores.sh by default. Skip it with --no-ios or PUBLISH_INCLUDE_IOS=0.
# Optional override (default: com.acypher.nunus.ios)
# IOS_BUNDLE_ID=com.acypher.nunus.ios
# PUBLISH_INCLUDE_IOS=0
# Safari submit-for-review is automated after upload in publish-stores.sh.
# APP_STORE_WHATS_NEW=Bug fixes and improvements.
# APP_STORE_WHATS_NEW_FILE=/path/to/whats-new.txt
# APP_STORE_LOCALE=en-US
# Listing description/subtitle synced before submit (docs/description.md).
# APP_STORE_DESCRIPTION_FILE=/path/to/description.md
# STORE_DESCRIPTION_FILE=/path/to/description.md
# APP_STORE_BUILD_WAIT_MINUTES=45
# APP_STORE_SKIP_SUBMIT=1
# App Store Connect API key (preferred)
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Path to AuthKey_XXXXXX.p8 (keep outside repo or in scripts/keys/, also gitignored)
APP_STORE_CONNECT_API_KEY_PATH=
# Fallback if you do not use an API key:
# APPLE_ID=you@example.com
# APPLE_APP_SPECIFIC_PASSWORD=

# --- Daily publish-check (after publish-stores.sh) ---
# Notifies when the published version is live on all three stores, then stops.
# PUBLISH_CHECK_NOTIFY_EMAIL=code@acypher.com
# PUBLISH_CHECK_DAILY_HOUR=9
# PUBLISH_CHECK_DAILY_MINUTE=0
# PUBLISH_CHECK_SKIP_DAILY=1
# APP_STORE_AUTO_RELEASE=1
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_SSL=1
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=code@acypher.com
