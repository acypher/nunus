.DS_Store
.idea/

# Release credentials and local keys (never commit)
scripts/release.env
scripts/release.env*
!scripts/release.env.example
scripts/keys/
*.p8

# Xcode per-user state (not shared)
**/xcuserdata/

# Local Safari build artifacts / backup projects
safari/build/
safari/NunusSafari (from backup).xcodeproj/

# Daily publish-check watcher state and logs
scripts/.publish-check-watch.json
scripts/.missed-articles-daily.json
scripts/logs/

# Python bytecode caches
__pycache__/
*.pyc
