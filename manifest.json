{
  "manifest_version": 3,
  "name": "Nunus",
  "version": "1.0.1",
  "description": "Gray out news articles you've already viewed on NYT, Washington Post, and The Guardian. 'Viewed' means the top third was visible for at least 3 seconds.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "*://www.nytimes.com/",
        "*://www.nytimes.com/*",
        "*://www.washingtonpost.com/",
        "*://www.washingtonpost.com/*",
        "*://www.theguardian.com/",
        "*://www.theguardian.com/*",
        "*://theguardian.com/",
        "*://theguardian.com/*",
        "*://guardian.co.uk/",
        "*://guardian.co.uk/*"
      ],
      "js": [
        "core.js",
        "sites/nyt.js",
        "sites/washingtonpost.js",
        "sites/guardian.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
