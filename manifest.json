{
  "manifest_version": 3,
  "name": "Nunus",
  "version": "1.2.3",
  "description": "On the nytimes.com front page, Nunus grays out article titles you've already seen. Also, autoplay is removed from videos.",
  "browser_specific_settings": {
    "gecko": {
      "id": "nunus@nunus.extension",
      "strict_min_version": "128.0"
    }
  },
  "icons": {
    "48": "icons/letterNu48.png",
    "96": "icons/letterNu96.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.nytimes.com/*",
    "https://nytimes.com/*",
    "https://*.nytimes.com/*",
    "https://washingtonpost.com/*",
    "https://www.washingtonpost.com/*",
    "https://www.theguardian.com/*",
    "https://theguardian.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "48": "icons/letterNu48.png",
      "96": "icons/letterNu96.png"
    },
    "default_popup": "popup.html",
    "default_title": "Nunus"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.nytimes.com/*",
        "https://nytimes.com/*",
        "https://*.nytimes.com/*"
      ],
      "js": ["ext-chrome-shim.js", "sites/nyt-autoplay-pref.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.nytimes.com/*",
        "https://nytimes.com/*",
        "https://*.nytimes.com/*"
      ],
      "js": ["ext-chrome-shim.js", "sites/nyt-betamax-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.nytimes.com/*",
        "https://nytimes.com/*",
        "https://*.nytimes.com/*"
      ],
      "js": ["ext-chrome-shim.js", "sites/nyt-videos.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.nytimes.com/*",
        "https://nytimes.com/*",
        "https://*.nytimes.com/*",
        "https://washingtonpost.com/",
        "https://www.theguardian.com/us"
      ],
      "js": [
        "ext-chrome-shim.js",
        "core.js",
        "sites/nyt.js",
        "sites/washingtonpost.js",
        "sites/guardian.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
