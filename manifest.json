{
  "manifest_version": 3,
  "name": "Nunus",
  "version": "2.0.1",
  "description": "Gray out NYTimes and Google News headlines you have seen.",
  "browser_specific_settings": {
    "gecko": {
      "id": "nunus@nunus.extension",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "strict_min_version": "128.0"
    }
  },
  "icons": {
    "48": "icons/letterNu48.png",
    "96": "icons/letterNu96.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.nytimes.com/",
    "https://www.nytimes.com/?*",
    "https://nytimes.com/",
    "https://nytimes.com/?*",
    "https://*.nytimes.com/",
    "https://*.nytimes.com/?*",
    "https://news.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "48": "icons/letterNu48.png",
      "96": "icons/letterNu96.png"
    },
    "default_popup": "popup.html",
    "default_title": "Nunus"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.nytimes.com/",
        "https://www.nytimes.com/?*",
        "https://nytimes.com/",
        "https://nytimes.com/?*",
        "https://*.nytimes.com/",
        "https://*.nytimes.com/?*"
      ],
      "js": [
        "ext-chrome-shim.js",
        "core.js",
        "sites/nyt.js",
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://news.google.com/*"
      ],
      "js": [
        "ext-chrome-shim.js",
        "core.js",
        "sites/googlenews.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
