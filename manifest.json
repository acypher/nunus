{
  "manifest_version": 3,
  "name": "Nunus",
  "version": "1.0.1",
  "description": "Gray out news articles you've already viewed on NYT, Washington Post, and The Guardian. 'Viewed' means the top third was visible for at least 3 seconds.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nunus"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.nytimes.com/",
        "https://washingtonpost.com/",
        "https://www.theguardian.com/us"
      ],
      "js": [
        "core.js",
        "sites/nyt.js",
        "sites/washingtonpost.js",
        "sites/guardian.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}